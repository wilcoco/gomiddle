# Copy this file to .env, fill in real values, and never commit .env.
# Load it with:  set -a; source .env; set +a

# HTTP API
HTTP_ADDR=:8080

# Silo PLC (Modbus TCP)
SILO_PLC_ADDR=10.10.41.50:2008
SILO_UNIT_ID=1
SILO_COUNT=6
SILO_SCALE=100
# Forward a silo weight only when it moves at least this many tons (the
# "meaningful change" threshold). Smaller = more events, noisier.
SILO_CHANGE_TONS=0.3
POLL_INTERVAL=2s
PLC_TIMEOUT=3s

# Injection-molding PLCs (Mitsubishi MC Protocol 3E binary)
INJ_MACHINES=1=10.10.41.21:3001,2=10.10.41.31:3001
INJ_POLL_INTERVAL=1s

# Set to true to serve fake PLC data without hardware (local development)
MOCK_PLC=false
