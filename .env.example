# Copy this file to .env, fill in real values, and never commit .env.
# Load it with:  set -a; source .env; set +a

# HTTP API
HTTP_ADDR=:8080

# Silo PLC (Modbus TCP)
SILO_PLC_ADDR=10.10.41.50:2008
SILO_UNIT_ID=1
SILO_COUNT=6
SILO_SCALE=100
POLL_INTERVAL=2s
PLC_TIMEOUT=3s

# Set to true to serve fake silo data without a PLC (local development)
MOCK_PLC=false
